datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   
  imagePath String?  
  createdAt DateTime @default(now())
  category  String   // Простий рядок (обов'язкове поле)
}